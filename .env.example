# Campus Controller Configuration (existing proxy — used by /api/* routes)
CAMPUS_CONTROLLER_URL=https://your-controller.example.com

# Development: Direct connection to Campus Controller (optional)
# Only used in development mode when not using the proxy
VITE_DEV_CAMPUS_CONTROLLER_URL=https://your-controller.example.com:443

# Port Configuration (Railway will set this automatically)
PORT=3000

# Auto-Login Credentials (Optional - for production deployments)
# If set, the app will automatically authenticate with the Campus Controller on load
VITE_CAMPUS_CONTROLLER_USER=admin
VITE_CAMPUS_CONTROLLER_PASSWORD=your_password_here

# Optional: Supabase Configuration for Historical Data
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── XIQ + Inlets Integration ──────────────────────────────────────────────────
# Routes:  /cloud/*      → ExtremeCloud IQ API
#          /controller/* → Campus Controller via Inlets tunnel

# ExtremeCloud IQ (cloud inventory, devices, SSIDs)
# Auth: logs in via POST /login — no static token needed
XIQ_BASE_URL=https://cal-api.extremecloudiq.com
XIQ_API_VERSION=v2
XIQ_USERNAME=<your-xiq-email>
XIQ_PASSWORD=<your-xiq-password>

# Campus Controller via Inlets tunnel (RF profiles, WLANs, runtime state)
INLETS_CONTROLLER_BASE_URL=https://calr1-inlets.extremecloudiq.com:5825

# Controller OAuth2 credentials (used by tokenService for password-grant auth)
CONTROLLER_CLIENT_ID=<client-id>
CONTROLLER_CLIENT_SECRET=<client-secret>
CONTROLLER_USERNAME=<controller-admin-username>
CONTROLLER_PASSWORD=<controller-admin-password>

# Optional: existing API gateway base URL
API_GATEWAY_BASE_URL=

# Logging level: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# CORS: comma-separated list of allowed origins (leave blank to allow all in dev)
ALLOWED_ORIGINS=
